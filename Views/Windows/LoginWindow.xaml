<Window x:Class="TourAgency2018.Views.Windows.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TourAgency2018.Views.Windows"
        mc:Ignorable="d"
        Icon="/Resources/логотип.png"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Title="Туристическое агенство 2018 - Авторизация" Height="400" Width="400">
    <Grid Background="{DynamicResource MainBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="83"/>
            <RowDefinition Height="330*"/>
            <RowDefinition Height="21*"/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal"
                    Background="{DynamicResource InformationalBackground}">
            <Image 
                Source="/Resources/логотип.png"
                RenderOptions.BitmapScalingMode="HighQuality"
                Margin="5"/>
            <StackPanel Orientation="Vertical" Margin="10">
                <TextBlock FontSize="19" HorizontalAlignment="Center" Text="Туристическое агенство 2018"/>
                <TextBlock FontSize="20" HorizontalAlignment="Center" Text="Авторизация"/>
            </StackPanel>
        </StackPanel>
        <Grid 
            Grid.Row="1"
            Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="88*"/>
                <RowDefinition Height="68*"/>
                <RowDefinition Height="36*"/>
                <RowDefinition Height="71*"/>
            </Grid.RowDefinitions>
            <TextBlock 
                FontSize="25" 
                Text="Логин"
                VerticalAlignment="Center" Height="34"/>
            <TextBox
                x:Name="LoginTextBox"
                Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}"
                Grid.Column="1"
                Width="250"
                HorizontalAlignment="Center"
                FontSize="25"
                BorderBrush="{DynamicResource BorderColor}"
                PreviewTextInput="AlphanumericOnly_PreviewTextInput"/>
            <TextBlock
                FontSize="25" 
                Text="Пароль" 
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Grid.Row="1"
                Height="35" 
                Width="93"/>
            <PasswordBox
                x:Name="PasswordBox"
                PasswordChanged="PasswordBox_PasswordChanged"
                KeyDown="PasswordBox_KeyDown"
                PreviewTextInput="AlphanumericOnly_PreviewTextInput"
                Grid.Row="1"
                Grid.Column="1"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Width="250"
                FontSize="25"
                BorderBrush="{DynamicResource BorderColor}"/>
            <TextBlock
                FontSize="15"
                x:Name="ErrorMessage"
                TextWrapping="Wrap"
                VerticalAlignment="Center"
                HorizontalAlignment="Left"
                Grid.Row="2"
                Grid.ColumnSpan="2"
                Visibility="Visible"
                Foreground="{DynamicResource AttentionColor}"/>
            <Button 
                x:Name="LoginButton"
                Click="LoginButton_Click"
                Grid.Row="3" 
                Content="Войти" 
                Grid.ColumnSpan="2"
                Margin="10"
                FontSize="20"/>
        </Grid>
        <Grid Grid.Row="2" Background="{DynamicResource AdditionalBackground}" />
    </Grid>
</Window>
