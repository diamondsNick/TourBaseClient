<Page x:Class="TourAgency2018.Views.Pages.ClientEditPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ClientEditPage"
      KeepAlive="False">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="30,20,30,20" MaxWidth="500" HorizontalAlignment="Left">

            <TextBlock x:Name="PageTitle"
                       FontSize="22"
                       FontWeight="Bold"
                       Margin="0,0,0,20"/>

            <TextBlock Text="Фамилия" FontSize="15" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="SurnameBox"
                     FontSize="15"
                     Padding="5"
                     Margin="0,0,0,15"
                     Width="300"
                     HorizontalAlignment="Left"/>

            <TextBlock Text="Имя" FontSize="15" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="NameBox"
                     FontSize="15"
                     Padding="5"
                     Margin="0,0,0,15"
                     Width="300"
                     HorizontalAlignment="Left"/>

            <TextBlock Text="Отчество" FontSize="15" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="PatronymicBox"
                     FontSize="15"
                     Padding="5"
                     Margin="0,0,0,15"
                     Width="300"
                     HorizontalAlignment="Left"/>

            <TextBlock Text="Дата рождения" FontSize="15" FontWeight="Bold" Margin="0,0,0,5"/>
            <DatePicker x:Name="DateOfBirthPicker"
                        Width="180"
                        HorizontalAlignment="Left"
                        Margin="0,0,0,15"
                        DisplayDateEnd="{x:Static sys:DateTime.Today}"
                        xmlns:sys="clr-namespace:System;assembly=mscorlib"/>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <StackPanel Margin="0,0,30,0">
                    <TextBlock Text="Серия паспорта" FontSize="15" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox x:Name="PassportSeriesBox"
                             FontSize="15"
                             Padding="5"
                             Width="120"
                             MaxLength="6"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="Номер паспорта" FontSize="15" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox x:Name="PassportNumberBox"
                             FontSize="15"
                             Padding="5"
                             Width="160"
                             MaxLength="4"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <Button Content="Сохранить"
                        Padding="20,8"
                        Margin="0,0,10,0"
                        Click="Save_Click"/>
                <Button Content="Отмена"
                        Padding="20,8"
                        Click="Cancel_Click"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
