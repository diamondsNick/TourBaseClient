<Page x:Class="TourAgency2018.Views.Pages.ClientEditPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ClientEditPage"
      KeepAlive="False">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="30,20,30,20" MaxWidth="500" HorizontalAlignment="Left">

            <TextBlock x:Name="PageTitle"
                       FontSize="22"
                       FontWeight="Bold"
                       Margin="0,0,0,20"/>

            <TextBlock Text="Фамилия" FontSize="15" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="SurnameBox"
                     FontSize="15"
                     Padding="5"
                     Margin="0,0,0,15"
                     Width="300"
                     HorizontalAlignment="Left"/>

            <TextBlock Text="Имя" FontSize="15" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="NameBox"
                     FontSize="15"
                     Padding="5"
                     Margin="0,0,0,15"
                     Width="300"
                     HorizontalAlignment="Left"/>

            <TextBlock Text="Отчество" FontSize="15" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="PatronymicBox"
                     FontSize="15"
                     Padding="5"
                     Margin="0,0,0,15"
                     Width="300"
                     HorizontalAlignment="Left"/>

            <TextBlock Text="Логин" FontSize="15" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="LoginBox"
                     FontSize="15"
                     Padding="5"
                     Margin="0,0,0,15"
                     Width="300"
                     HorizontalAlignment="Left"
                     PreviewTextInput="AlphanumericOnly_PreviewTextInput"/>

            <TextBlock x:Name="PasswordLabel" Text="Пароль" FontSize="15" FontWeight="Bold" Margin="0,0,0,5"/>
            <PasswordBox x:Name="PasswordBox"
                         FontSize="15"
                         Padding="5"
                         Margin="0,0,0,5"
                         Width="300"
                         HorizontalAlignment="Left"
                         PreviewTextInput="AlphanumericOnly_PreviewTextInput"/>
            <TextBlock x:Name="PasswordHint"
                       Text="Оставьте пустым, чтобы не менять пароль"
                       FontSize="12"
                       Foreground="Gray"
                       Margin="0,0,0,15"
                       Visibility="Collapsed"/>

            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                <Button Content="Сохранить"
                        Padding="20,8"
                        Margin="0,0,10,0"
                        Click="Save_Click"/>
                <Button Content="Отмена"
                        Padding="20,8"
                        Click="Cancel_Click"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
