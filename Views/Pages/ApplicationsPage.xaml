<Page x:Class="TourAgency2018.Views.Pages.ApplicationsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="900"
      Title="Заявки на туры"
      KeepAlive="False">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Панель фильтров -->
        <StackPanel Orientation="Horizontal" Margin="10,8,10,8" VerticalAlignment="Center">
            <TextBox x:Name="SearchTextBox"
                     Width="250"
                     Padding="5"
                     FontSize="14"
                     Text="Поиск по клиенту или туру..."
                     Foreground="Gray"
                     GotFocus="SearchTextBox_GotFocus"
                     LostFocus="SearchTextBox_LostFocus"
                     TextChanged="SearchTextBox_TextChanged"/>
            <TextBlock Text="Статус" Margin="15,0,5,0" VerticalAlignment="Center"/>
            <ComboBox x:Name="StatusFilterBox"
                      Width="140"
                      Padding="5"
                      SelectionChanged="StatusFilterBox_SelectionChanged"/>
            <Button Content="Сбросить"
                    Margin="8,0,0,0"
                    Padding="12,0"
                    Click="ClearFilters_Click"/>
            <TextBlock x:Name="RecordCountText"
                       Margin="15,0,0,0"
                       VerticalAlignment="Center"
                       FontSize="13"
                       Foreground="Gray"/>
        </StackPanel>

        <!-- DataGrid -->
        <DataGrid x:Name="ApplicationsDataGrid"
                  Grid.Row="1"
                  Margin="10"
                  ItemsSource="{Binding ApplicationsList}"
                  SelectedItem="{Binding SelectedApplication, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  CanUserResizeRows="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  RowHeight="36"
                  FontSize="14">
            <DataGrid.Columns>
                <DataGridTextColumn Header="№ заявки" Binding="{Binding Id}" Width="90"/>
                <DataGridTextColumn Header="Клиент" Binding="{Binding ClientFullName}" Width="220"/>
                <DataGridTextColumn Header="Тур" Binding="{Binding TourName}" Width="*"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="130"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
