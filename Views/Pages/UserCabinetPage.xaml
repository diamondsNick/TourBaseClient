<Page x:Class="TourAgency2018.Views.Pages.UserCabinetPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="UserCabinetPage"
      KeepAlive="False">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="40">

            <TextBlock Text="Личный кабинет"
                       FontSize="22" FontWeight="Bold"
                       Margin="0,0,0,25"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Личная информация (левая колонка) -->
                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="Личная информация" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

                    <TextBlock Text="Фамилия" Margin="0,0,0,3"/>
                    <TextBlock x:Name="SurnameText" FontSize="15" Margin="0,0,0,10"/>

                    <TextBlock Text="Имя" Margin="0,0,0,3"/>
                    <TextBlock x:Name="NameText" FontSize="15" Margin="0,0,0,10"/>

                    <TextBlock Text="Отчество" Margin="0,0,0,3"/>
                    <TextBlock x:Name="PatronymicText" FontSize="15" Margin="0,0,0,10"/>

                    <TextBlock Text="Роль" Margin="0,0,0,3"/>
                    <TextBlock x:Name="RoleText" FontSize="15"/>
                </StackPanel>

                <!-- Смена пароля (правая колонка) -->
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Смена пароля" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

                    <TextBlock Text="Текущий пароль" Margin="0,0,0,3"/>
                    <PasswordBox x:Name="CurrentPasswordBox" Padding="5" FontSize="14" Margin="0,0,0,12" Width="200" HorizontalAlignment="Left"
                                 PreviewTextInput="AlphanumericOnly_PreviewTextInput"/>

                    <TextBlock Text="Новый пароль" Margin="0,0,0,3"/>
                    <PasswordBox x:Name="NewPasswordBox" Padding="5" FontSize="14" Margin="0,0,0,12" Width="200" HorizontalAlignment="Left"
                                 PreviewTextInput="AlphanumericOnly_PreviewTextInput"/>

                    <TextBlock Text="Повторите новый пароль" Margin="0,0,0,3"/>
                    <PasswordBox x:Name="ConfirmPasswordBox" Padding="5" FontSize="14" Margin="0,0,0,5" Width="200" HorizontalAlignment="Left"
                                 PreviewTextInput="AlphanumericOnly_PreviewTextInput"/>

                    <TextBlock x:Name="ErrorText" Foreground="Red" FontSize="13"
                               TextWrapping="Wrap" Margin="0,0,0,15" Visibility="Collapsed"/>

                    <Button Content="Сохранить и выйти"
                            Padding="20,8"
                            HorizontalAlignment="Left"
                            Click="SaveButton_Click"/>
                </StackPanel>

            </Grid>

        </StackPanel>
    </ScrollViewer>
</Page>
