<Page x:Class="TourAgency2018.Views.Pages.ApplicationEditPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="600" d:DesignWidth="800"
      Title="ApplicationEditPage"
      KeepAlive="False">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="30,20,30,20" MaxWidth="550" HorizontalAlignment="Left">

            <TextBlock x:Name="PageTitle"
                       FontSize="22" FontWeight="Bold"
                       Margin="0,0,0,20"/>

            <!-- Клиент -->
            <TextBlock Text="Клиент" FontSize="15" FontWeight="Bold" Margin="0,0,0,5"/>
            <ComboBox x:Name="ClientBox"
                      Width="350" HorizontalAlignment="Left"
                      Padding="5" FontSize="14"
                      DisplayMemberPath="FullName"
                      Margin="0,0,0,15"/>

            <!-- Тур -->
            <TextBlock Text="Тур" FontSize="15" FontWeight="Bold" Margin="0,0,0,5"/>
            <ComboBox x:Name="TourBox"
                      Width="350" HorizontalAlignment="Left"
                      Padding="5" FontSize="14"
                      DisplayMemberPath="Name"
                      Margin="0,0,0,15"
                      SelectionChanged="TourBox_SelectionChanged"/>

            <!-- Статус -->
            <TextBlock Text="Статус" FontSize="15" FontWeight="Bold" Margin="0,0,0,5"/>
            <ComboBox x:Name="StatusBox"
                      Width="200" HorizontalAlignment="Left"
                      Padding="5" FontSize="14"
                      Margin="0,0,0,15"/>

            <!-- Дата заявки -->
            <TextBlock Text="Дата заявки" FontSize="15" FontWeight="Bold" Margin="0,0,0,5"/>
            <DatePicker x:Name="ApplicationDatePicker"
                        Width="180" HorizontalAlignment="Left"
                        Margin="0,0,0,20"/>

            <!-- Дополнительные услуги -->
            <TextBlock Text="Дополнительные услуги" FontSize="15" FontWeight="Bold" Margin="0,0,0,5"/>
            <Border BorderBrush="LightGray" BorderThickness="1" Padding="10" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock x:Name="NoServicesPlaceholder"
                               FontSize="13" Foreground="Gray"
                               Text="Сначала выберите тур"/>
                    <ItemsControl x:Name="ServicesList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding Name}"
                                          IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                          FontSize="14"
                                          Margin="0,3,0,3"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Кнопки -->
            <StackPanel Orientation="Horizontal">
                <Button Content="Сохранить" Padding="20,8" Margin="0,0,10,0" Click="Save_Click"/>
                <Button Content="Отмена" Padding="20,8" Click="Cancel_Click"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
