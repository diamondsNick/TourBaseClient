<Page x:Class="TourAgency2018.Views.Pages.HotelEditPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:conv="clr-namespace:TourAgency2018.ViewModels"
      mc:Ignorable="d"
      d:DesignHeight="700" d:DesignWidth="900"
      Title="HotelEditPage"
      KeepAlive="False">

    <Page.Resources>
        <conv:PhotoConverter x:Key="PhotoConverterFromBytes"/>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">

            <TextBlock x:Name="PageTitle" FontSize="22" FontWeight="Bold" Margin="0,0,0,15"/>

            <!-- Фото -->
            <TextBlock Text="Фотография" FontSize="16" FontWeight="Bold" Margin="0,0,0,5"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                <Image x:Name="PreviewImage"
                       Width="200" Height="130"
                       Stretch="Uniform"
                       Margin="0,0,15,0"/>
                <Button Content="Выбрать фото"
                        VerticalAlignment="Center"
                        Padding="12,6"
                        Click="SelectPhoto_Click"/>
            </StackPanel>

            <!-- Название -->
            <TextBlock Text="Название" FontSize="16" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="NameBox" Width="300" HorizontalAlignment="Left" Margin="0,0,0,15" Padding="5" FontSize="15"/>

            <!-- Страна и звёзды -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                <StackPanel Margin="0,0,30,0">
                    <TextBlock Text="Страна" FontSize="16" FontWeight="Bold" Margin="0,0,0,5"/>
                    <ComboBox x:Name="CountryBox" Width="200" Padding="5" DisplayMemberPath="Name"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="Звёзд" FontSize="16" FontWeight="Bold" Margin="0,0,0,5"/>
                    <ComboBox x:Name="StarsBox" Width="80" Padding="5"/>
                </StackPanel>
            </StackPanel>

            <!-- Тип питания -->
            <TextBlock Text="Тип питания" FontSize="16" FontWeight="Bold" Margin="0,0,0,5"/>
            <ComboBox x:Name="MealTypeBox" Width="200" HorizontalAlignment="Left" Padding="5" DisplayMemberPath="Name" Margin="0,0,0,15"/>

            <!-- Кнопки -->
            <StackPanel Orientation="Horizontal">
                <Button Content="Сохранить" Padding="20,8" Margin="0,0,10,0" Click="Save_Click"/>
                <Button Content="Отмена" Padding="20,8" Click="Cancel_Click"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
