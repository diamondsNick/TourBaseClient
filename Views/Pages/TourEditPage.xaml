<Page x:Class="TourAgency2018.Views.Pages.TourEditPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:conv="clr-namespace:TourAgency2018.ViewModels"
      mc:Ignorable="d"
      d:DesignHeight="700" d:DesignWidth="900"
      Title="TourEditPage"
      KeepAlive="False">

    <Page.Resources>
        <conv:PhotoConverter x:Key="PhotoConverterFromBytes"/>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">

            <TextBlock x:Name="PageTitle" FontSize="22" FontWeight="Bold" Margin="0,0,0,15"/>

            <!-- Фото -->
            <TextBlock Text="Фотография" FontSize="16" FontWeight="Bold" Margin="0,0,0,5"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                <Image x:Name="PreviewImage"
                       Width="200" Height="130"
                       Stretch="Uniform"
                       Margin="0,0,15,0"/>
                <Button Content="Выбрать фото"
                        VerticalAlignment="Center"
                        Padding="12,6"
                        Click="SelectPhoto_Click"/>
            </StackPanel>

            <!-- Основные поля -->
            <TextBlock Text="Название" FontSize="16" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="NameBox" Width="300" Margin="0,0,0,15" Padding="5" FontSize="15"/>

            <TextBlock Text="Описание" FontSize="16" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="DescriptionBox" 
                     Margin="0,0,0,15" 
                     Padding="5" 
                     FontSize="15"
                     AcceptsReturn="True" 
                     TextWrapping="Wrap" 
                     Height="80"
                     Width="300"
                     VerticalScrollBarVisibility="Auto"/>

            <!-- Стоимость и билеты -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                <StackPanel Margin="0,0,30,0">
                    <TextBlock Text="Стоимость (руб.)" FontSize="16" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox x:Name="PriceBox" Width="150" Padding="5" FontSize="15"/>
                </StackPanel>
                <StackPanel Margin="0,0,30,0">
                    <TextBlock Text="Кол-во билетов" FontSize="16" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox x:Name="TicketsBox" Width="150" Padding="5" FontSize="15"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="Активный" FontSize="16" FontWeight="Bold" Margin="0,0,0,5"/>
                    <CheckBox x:Name="IsActualBox" VerticalAlignment="Center" Width="30" Height="30"/>
                </StackPanel>
            </StackPanel>

            <!-- Даты -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                <StackPanel Margin="0,0,30,0">
                    <TextBlock Text="Дата начала" FontSize="16" FontWeight="Bold" Margin="0,0,0,5"/>
                    <DatePicker x:Name="StartDateBox" Width="160"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="Дата окончания" FontSize="16" FontWeight="Bold" Margin="0,0,0,5"/>
                    <DatePicker x:Name="EndDateBox" Width="160"/>
                </StackPanel>
            </StackPanel>

            <!-- Типы -->
            <TextBlock Text="Типы тура" FontSize="16" FontWeight="Bold" Margin="0,0,0,5"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <ComboBox x:Name="TypesComboBox" Width="200" Padding="5" DisplayMemberPath="Name"/>
                <Button Content="Добавить" Margin="8,0,0,0" Padding="10,5" Click="AddType_Click"/>
            </StackPanel>
            <ItemsControl x:Name="SelectedTypesList" Margin="0,0,0,15">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
                            <TextBlock Text="{Binding Name}" FontSize="14" VerticalAlignment="Center" Width="200"/>
                            <Button Content="✕" Padding="6,2" Click="RemoveType_Click" Tag="{Binding}"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Отели -->
            <TextBlock Text="Отели" FontSize="16" FontWeight="Bold" Margin="0,0,0,5"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <ComboBox x:Name="HotelsComboBox" Width="200" Padding="5" DisplayMemberPath="Name"/>
                <Button Content="Добавить" Margin="8,0,0,0" Padding="10,5" Click="AddHotel_Click"/>
            </StackPanel>
            <ItemsControl x:Name="SelectedHotelsList" Margin="0,0,0,15">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
                            <TextBlock Text="{Binding Name}" FontSize="14" VerticalAlignment="Center" Width="200"/>
                            <Button Content="✕" Padding="6,2" Click="RemoveHotel_Click" Tag="{Binding}"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Услуги -->
            <TextBlock Text="Дополнительные услуги" FontSize="16" FontWeight="Bold" Margin="0,0,0,5"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <ComboBox x:Name="ServicesComboBox" Width="200" Padding="5" DisplayMemberPath="Name"/>
                <Button Content="Добавить" Margin="8,0,0,0" Padding="10,5" Click="AddService_Click"/>
            </StackPanel>
            <ItemsControl x:Name="SelectedServicesList" Margin="0,0,0,20">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
                            <TextBlock Text="{Binding Name}" FontSize="14" VerticalAlignment="Center" Width="200"/>
                            <Button Content="✕" Padding="6,2" Click="RemoveService_Click" Tag="{Binding}"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Кнопки -->
            <StackPanel Orientation="Horizontal">
                <Button Content="Сохранить" Padding="20,8" Margin="0,0,10,0" Click="Save_Click"/>
                <Button Content="Отмена" Padding="20,8" Click="Cancel_Click"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
